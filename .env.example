# idOS Node URL (production)
NEXT_PUBLIC_KWIL_NODE_URL=https://nodes.idos.network

# WalletConnect Project ID
# Get at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Backend Consumer Keys (KEEP THESE SECRET - Server-side only)
# Generate these using: npm run generate-keys
CONSUMER_SIGNING_SECRET_KEY=your_64_byte_hex_encoded_nacl_signing_secret_key
CONSUMER_ENCRYPTION_SECRET_KEY=your_base64_encoded_nacl_box_secret_key

# Public keys for frontend (derive from secret keys above)
NEXT_PUBLIC_CONSUMER_SIGNING_PUBLIC_KEY=your_32_byte_hex_public_key
NEXT_PUBLIC_CONSUMER_ENCRYPTION_PUBLIC_KEY=your_base64_public_key

# SurrealDB (for storing PoP NFT claims — schema auto-creates on first query)
# Local development: share the OTER stack's SurrealDB server on :8000; the app
# isolates itself in its own namespace. Production: a dedicated instance.
SURREALDB_URL=http://127.0.0.1:8000
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NAMESPACE=idos_pop
SURREALDB_DATABASE=idos_pop

# Page origin for ROLA verification — MUST equal the origin users load the app
# from (the wallet signs it into every proof). Dev default: http://localhost:3002.
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Radix Network Configuration
# Network: "mainnet" or "stokenet" (testnet)
NEXT_PUBLIC_RADIX_NETWORK=stokenet

# Gateway URL (will auto-select based on network if not set)
# Stokenet: https://stokenet.radixdlt.com
# Mainnet: https://mainnet.radixdlt.com
NEXT_PUBLIC_GATEWAY_URL=https://stokenet.radixdlt.com

# Radix dApp Configuration
# dApp Definition Address (same as backend account address)
# This needs NEXT_PUBLIC_ prefix to be accessible in the browser
# Mainnet: account_rdx...
# Stokenet: account_tdx_2_...
NEXT_PUBLIC_RADIX_DAPP_DEFINITION_ADDRESS=your_backend_account

# Radix Backend Configuration (Server-side only)
RADIX_BACKEND_ACCOUNT_ADDRESS=your_backend_account
RADIX_BACKEND_PRIVATE_KEY=your_backend_private_key

# Smart contracts and resources
RADIX_POP_COMPONENT_ADDRESS=your_component_address
RADIX_COMPONENT_ADMIN_BADGE_ADDRESS=your_admin_badge_address
