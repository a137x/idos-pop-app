# Per-network service variables for the PoP web portal (copy to
# vars-mainnet.env / vars-stokenet.env — BOTH GITIGNORED, they hold secrets).
# SURREALDB_* wiring is appended automatically by setup-services.sh.

# ── build-time (baked into the JS bundle via Dockerfile ARGs) ──
NEXT_PUBLIC_KWIL_NODE_URL=https://nodes.idos.network
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_CONSUMER_SIGNING_PUBLIC_KEY=
NEXT_PUBLIC_CONSUMER_ENCRYPTION_PUBLIC_KEY=
# MUST equal the public origin — it is a ROLA + key-derivation input (permanent!)
NEXT_PUBLIC_APP_URL=https://idos.oter.io
NEXT_PUBLIC_RADIX_NETWORK=mainnet
NEXT_PUBLIC_GATEWAY_URL=https://mainnet.radixdlt.com
# = pop-backend account (permanent once users onboard — also a derivation input)
NEXT_PUBLIC_RADIX_DAPP_DEFINITION_ADDRESS=

# ── runtime (server only) ──
CONSUMER_SIGNING_SECRET_KEY=
CONSUMER_ENCRYPTION_SECRET_KEY=
RADIX_BACKEND_ACCOUNT_ADDRESS=
RADIX_BACKEND_PRIVATE_KEY=
RADIX_POP_COMPONENT_ADDRESS=
RADIX_COMPONENT_ADMIN_BADGE_ADDRESS=
